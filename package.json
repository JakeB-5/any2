{
  "name": "any2",
  "version": "1.0.0",
  "description": "Universal data format converter - convert anything to anything",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "any2": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --no-cache",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "converter",
    "json",
    "yaml",
    "toml",
    "csv",
    "xml",
    "markdown",
    "cli",
    "transform",
    "format"
  ],
  "author": "anylabs",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "fast-xml-parser": "^4.5.0",
    "js-yaml": "^4.1.0",
    "marked": "^14.0.0",
    "smol-toml": "^1.3.0"
  }
}
